generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Utilisateur {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  mot_de_passe String
  nom         String
  prenom      String
  role        Role     @default(USER)
  date_creation DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isActive    Boolean  @default(true)

  commentaires    Commentaire[]
  likes           Like[]
  favoris         Favori[]
  historiques     HistoriqueExercice[]
}

model Categorie {
  id          Int      @id @default(autoincrement())
  nom         String
  description String   @db.Text

  exercices   ExerciceRespiration[]
  contenus    ContenuInformation[]
}

model ExerciceRespiration {
  id             Int      @id @default(autoincrement())
  titre          String
  description    String   @db.Text
  duree_secondes Int
  inspiration    Int
  apnee          Int
  expiration     Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categorieId    Int
  categorie      Categorie @relation(fields: [categorieId], references: [id])

  commentaires   Commentaire[]
  likes          Like[]
  favoris        Favori[]
  historiques    HistoriqueExercice[]
}

model ContenuInformation {
  id               Int      @id @default(autoincrement())
  titre            String
  contenu          String   @db.Text
  date_publication DateTime @default(now())
  updatedAt        DateTime @updatedAt
  isActive         Boolean  @default(true)

  categorieId      Int
  categorie        Categorie @relation(fields: [categorieId], references: [id])

  commentaires     Commentaire[]
  likes            Like[]
}

model Commentaire {
  id        Int      @id @default(autoincrement())
  contenu   String   @db.Text
  createdAt DateTime @default(now())

  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  exerciceId    Int?
  exercice      ExerciceRespiration? @relation(fields: [exerciceId], references: [id])

  contenuId     Int?
  contenuInfo   ContenuInformation? @relation(fields: [contenuId], references: [id])
}

model Like {
  id        Int      @id @default(autoincrement())
  date_like DateTime @default(now())

  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  exerciceId    Int?
  exercice      ExerciceRespiration? @relation(fields: [exerciceId], references: [id])

  contenuId     Int?
  contenuInfo   ContenuInformation? @relation(fields: [contenuId], references: [id])
}

model Favori {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])

  exerciceId    Int
  exercice      ExerciceRespiration @relation(fields: [exerciceId], references: [id])
}

model HistoriqueExercice {
  id               Int      @id @default(autoincrement())
  date_realisation DateTime @default(now())

  utilisateurId    Int
  utilisateur      Utilisateur @relation(fields: [utilisateurId], references: [id])

  exerciceId       Int
  exercice         ExerciceRespiration @relation(fields: [exerciceId], references: [id])
}

enum Role {
  USER
  ADMIN
}